# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=admin
POSTGRES_PASSWORD=admin123
POSTGRES_DB=agentdb
POSTGRES_DSN=postgres://admin:admin123@127.0.0.1:5432/agentdb?sslmode=disable

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=redispass
REDIS_URL=redis://:redispass@localhost:6380/0

# ── ClickHouse ────────────────────────────────────────────────────────────────
CLICKHOUSE_USER=admin
CLICKHOUSE_PASSWORD=admin123
CLICKHOUSE_DB=langfuse

# ── Langfuse ──────────────────────────────────────────────────────────────────
LANGFUSE_URL=http://localhost:3000
LANGFUSE_NEXTAUTH_SECRET=changeme-secret-32chars-minimum!!
LANGFUSE_SALT=changeme-salt

# Headless initialization — Langfuse creates these resources on first startup
# if they don't already exist (no manual UI setup needed).
LANGFUSE_INIT_ORG_ID=my-org
LANGFUSE_INIT_ORG_NAME=My Org
LANGFUSE_INIT_PROJECT_ID=my-project
LANGFUSE_INIT_PROJECT_NAME=My Project
LANGFUSE_INIT_PROJECT_PUBLIC_KEY=lf_pk_1234567890
LANGFUSE_INIT_PROJECT_SECRET_KEY=lf_sk_1234567890
LANGFUSE_INIT_USER_EMAIL=admin@example.com
LANGFUSE_INIT_USER_NAME=Admin
LANGFUSE_INIT_USER_PASSWORD=changeme123

# OTel collector — base64(public_key:secret_key)
# Generate: [Convert]::ToBase64String([Text.Encoding]::UTF8.GetBytes("lf_pk_...:lf_sk_..."))
LANGFUSE_OTLP_AUTH=bGZfcGs6bGZfc2s=
LANGFUSE_OTLP_ENDPOINT=http://localhost:4318

# ClickHouse migration URL (used by Langfuse on startup)
# Format: http://user:password@host:8123/database
CLICKHOUSE_MIGRATION_URL=http://admin:admin123@localhost:8123/langfuse

# Used by Go API server for direct Langfuse SDK calls
LANGFUSE_PUBLIC_KEY=lf_pk_1234567890
LANGFUSE_SECRET_KEY=lf_sk_1234567890

# ── Ollama ────────────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
PLANNER_MODEL=gemma4:e2b
EVAL_MODEL=gemma4:e2b
EMBED_MODEL=nomic-embed-text

# ── Go API server ─────────────────────────────────────────────────────────────
HTTP_ADDR=:8080
GIN_MODE=debug
GRPC_POOL_SIZE=5
PYTHON_GRPC_ADDR=localhost:50051
REFINEMENT_MAX_GENERATION=3

# Dev-mode agent (used when POSTGRES_DSN is not set)
DEV_AGENT_MODEL=gemma4:e2b
DEV_AGENT_SYSTEM_PROMPT=You are a helpful assistant.
DEV_AGENT_MAX_ITERATIONS=3
