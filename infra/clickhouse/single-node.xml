<clickhouse>
    <!-- Define a single-shard, single-replica "default" cluster so that
         Langfuse's "ON CLUSTER default" DDL is accepted. -->
    <remote_servers>
        <default>
            <shard>
                <replica>
                    <host>localhost</host>
                    <port>9000</port>
                </replica>
            </shard>
        </default>
    </remote_servers>

    <!-- Built-in ClickHouse Keeper (ZooKeeper replacement).
         Required for ReplicatedMergeTree on a single node. -->
    <keeper_server>
        <tcp_port>9181</tcp_port>
        <server_id>1</server_id>
        <log_storage_path>/var/lib/clickhouse/coordination/log</log_storage_path>
        <snapshot_storage_path>/var/lib/clickhouse/coordination/snapshots</snapshot_storage_path>
        <coordination_settings>
            <operation_timeout_ms>10000</operation_timeout_ms>
            <session_timeout_ms>30000</session_timeout_ms>
            <raft_logs_level>warning</raft_logs_level>
        </coordination_settings>
        <raft_configuration>
            <server>
                <id>1</id>
                <hostname>localhost</hostname>
                <port>9234</port>
            </server>
        </raft_configuration>
    </keeper_server>

    <!-- Point the ZooKeeper client to the built-in Keeper above -->
    <zookeeper>
        <node>
            <host>localhost</host>
            <port>9181</port>
        </node>
    </zookeeper>

    <!-- Replica identity macros referenced by ReplicatedMergeTree paths -->
    <macros>
        <cluster>default</cluster>
        <shard>01</shard>
        <replica>01</replica>
    </macros>
</clickhouse>
