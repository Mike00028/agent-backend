          edge="1" parent="1" source="graph_orchestrator" target="pgvector">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="rag_vector" value="semantic search"
          style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#9673a6;fontSize=11;"
          edge="1" parent="1" source="rag_graph" target="kb_store">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="tool_audit" value="persist tool I/O logs"
          style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#b85450;fontSize=11;"
